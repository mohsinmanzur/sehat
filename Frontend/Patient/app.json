{
  "expo": {
    "name": "Sehat Scan",
    "scheme": "com.mohsinmanzoor.sehatscan",
    "slug": "sehatscan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Logo.png",
    "splash": {
      "image": "./assets/Splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2A5CFF",
      "dark": {
        "image": "./assets/Splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#0D0D0E"
      }
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.mohsinmanzoor.sehatscan",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/Blank.png",
        "backgroundColor": "#2A5CFF"
      },
      "softwareKeyboardLayoutMode": "resize"
    },
    "extra": {
      "eas": {
        "projectId": "08842b17-c0b6-4540-846d-8e5f6e537fa3"
      }
    },
    "plugins": [
      "expo-router"
    ]
  }
}
