{
  "expo": {
    "name": "Sehat",
    "scheme": "com.mohsinmanzoor.sehatscan",
    "slug": "sehat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2A5CFF",
      "dark": {
        "image": "./assets/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#0D0D0E"
      }
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.mohsinmanzoor.sehatscan",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#2A5CFF"
      },
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "runtimeVersion": "1.0.0"
    },
    "extra": {
      "eas": {
        "projectId": "6e2d986c-d327-4df0-97c8-433795a5fa21"
      },
      "router": {
        "root": "./src/app"
      }
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./src/app"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Sehat Scan to access your camera."
        }
      ],
      "expo-sqlite",
      "expo-asset",
      "expo-font",
      "expo-secure-store"
    ],
    "owner": "mohsin_manzoor",
    "updates": {
      "url": "https://u.expo.dev/6e2d986c-d327-4df0-97c8-433795a5fa21",
      "requestHeaders": {
        "expo-channel-name": "preview"
      }
    },
    "ios": {
      "runtimeVersion": "1.0.0"
    }
  }
}